{
	"name": "n8n-nodes-abacus",
	"version": "0.1.0",
	"description": "n8n community node for the Abacus ERP REST API",
	"license": "MIT",
	"homepage": "https://github.com/SAITS/n8n-nodes-abacus",
	"bugs": {
		"url": "https://github.com/SAITS/n8n-nodes-abacus/issues"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"abacus",
		"erp"
	],
	"author": {
		"name": "SAITS"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/SAITS/n8n-nodes-abacus.git"
	},
	"engines": {
		"node": ">=22",
		"npm": ">=10"
	},
	"scripts": {
		"build": "node scripts/build.mjs",
		"build:watch": "tsc --watch",
		"dev": "node scripts/dev.mjs",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "npm run lint && npm run build",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AbacusApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Abacus/Abacus.node.js"
		]
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.7.0",
		"eslint": "^9.39.4",
		"prettier": "^3.8.1",
		"release-it": "^19.2.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
